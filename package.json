{
  "name": "read-receipts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Personal reading dashboard — static site that visualizes Hardcover reading history.",
  "scripts": {
    "fetch": "tsx scripts/fetch-books.ts",
    "dev": "vite",
    "build": "npm run fetch && tsc -b && vite build",
    "build:no-fetch": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
